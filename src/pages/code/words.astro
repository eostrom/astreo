---
import {getCollection} from 'astro:content'
import CodeGrid from '../../layouts/CodeGrid.astro'
import BlogPostExcerpt from '../../components/BlogPostExcerpt.astro'

const allCodePosts = (
  await getCollection(
    'words',
    ({data}) =>
      data.status !== 'draft' && ['code', 'both'].includes(data.section),
  )
)
  .toSorted((a, b) => Date.parse(a.data.date) - Date.parse(b.data.date))
  .toReversed()
---

<CodeGrid title="code[words]" displayOnly={true}>
  <h1>words</h1>

  {allCodePosts.map((post) => <BlogPostExcerpt post={post} />)}
</CodeGrid>
