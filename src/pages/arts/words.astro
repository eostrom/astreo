---
import {getCollection} from 'astro:content'
import ArtsGrid from '../../layouts/ArtsGrid.astro'
import BlogPostExcerpt from '../../components/BlogPostExcerpt.astro'

const allArtsPosts = (
  await getCollection(
    'words',
    ({data}) =>
      data.status !== 'draft' && ['arts', 'both'].includes(data.section),
  )
)
  .toSorted((a, b) => Date.parse(a.data.date) - Date.parse(b.data.date))
  .toReversed()
---

<ArtsGrid title="arts[words]" displayOnly={true}>
  <h1>words</h1>

  {allArtsPosts.map((post) => <BlogPostExcerpt post={post} />)}
</ArtsGrid>
